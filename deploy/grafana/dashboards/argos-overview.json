{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "links": [],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["argos"],
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "templating": {
    "list": [
      {
        "name": "trace_id",
        "label": "Trace",
        "type": "query",
        "datasource": { "type": "grafana-clickhouse-datasource", "uid": "argos-clickhouse" },
        "refresh": 1,
        "sort": 0,
        "includeAll": false,
        "multi": false,
        "definition": "SELECT concat(service_name, ' · ', if(countIf(status = 'error') > 0, 'fail', 'ok'), ' · ', formatDateTime(max(start_time), '%H:%i:%S', 'America/New_York')) AS trace FROM argos.spans WHERE trace_id IN (SELECT trace_id FROM argos.trace_nodes) GROUP BY trace_id, service_name ORDER BY max(start_time) DESC LIMIT 50",
        "query": {
          "refId": "A",
          "editorType": "sql",
          "queryType": "table",
          "format": 1,
          "rawSql": "SELECT concat(service_name, ' · ', if(countIf(status = 'error') > 0, 'fail', 'ok'), ' · ', formatDateTime(max(start_time), '%H:%i:%S', 'America/New_York')) AS trace FROM argos.spans WHERE trace_id IN (SELECT trace_id FROM argos.trace_nodes) GROUP BY trace_id, service_name ORDER BY max(start_time) DESC LIMIT 50"
        }
      }
    ]
  },
  "title": "Argos — Multi-Agent Trace Overview",
  "uid": "argos-overview",
  "version": 17,
  "panels": [
    {
      "id": 1,
      "title": "Critical findings",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "argos-prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "argos-prometheus" },
          "expr": "sum(argos_findings_total{severity=\"critical\"})",
          "instant": true,
          "legendFormat": "critical"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [{ "type": "value", "options": { "0": { "text": "0" } } }],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "title": "Last run cost (USD)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "argos-prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "argos-prometheus" },
          "expr": "argos_last_run_cost_usd",
          "instant": true
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "title": "Loops (last run)",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "argos-prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "argos-prometheus" },
          "expr": "argos_last_run_loops",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 15,
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "title": "Tool failures (last run)",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "argos-prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "argos-prometheus" },
          "expr": "argos_last_run_tool_failures",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 12,
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 3 },
              { "color": "red", "value": 6 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "title": "Findings by rule (cumulative)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "argos-prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "argos-prometheus" },
          "expr": "sum by (rule) (argos_findings_total)",
          "legendFormat": "{{rule}}"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "fillOpacity": 15,
            "showPoints": "auto"
          }
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "title": "Run cost over time (USD)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "argos-prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "argos-prometheus" },
          "expr": "argos_last_run_cost_usd",
          "legendFormat": "last run cost"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "fillOpacity": 20,
            "showPoints": "auto"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 7,
      "title": "Recent runs (per trace)",
      "type": "table",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "argos-clickhouse" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "argos-clickhouse" },
          "editorType": "sql",
          "queryType": "table",
          "format": 1,
          "rawSql": "SELECT concat(service_name, ' · ', if(countIf(status = 'error') > 0, 'fail', 'ok'), ' · ', formatDateTime(max(start_time), '%H:%i:%S', 'America/New_York')) AS run, count() AS steps, round(sum(cost_usd), 4) AS cost_usd, countIf(status = 'error') AS errors, max(start_time) AS last_seen FROM argos.spans GROUP BY trace_id, service_name ORDER BY last_seen DESC LIMIT 30"
        }
      ],
      "options": { "showHeader": true, "sortBy": [{ "displayName": "last_seen", "desc": true }] },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto", "filterable": true } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "run" },
            "properties": [
              { "id": "custom.width", "value": 240 },
              { "id": "custom.cellOptions", "value": { "type": "color-text" } },
              { "id": "mappings", "value": [
                { "type": "regex", "options": { "pattern": ".*· fail ·.*", "result": { "color": "red", "index": 0 } } },
                { "type": "regex", "options": { "pattern": ".*· ok ·.*", "result": { "color": "green", "index": 1 } } }
              ] }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "errors" },
            "properties": [
              { "id": "custom.cellOptions", "value": { "type": "color-background" } },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "red", "value": 1 }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "cost_usd" },
            "properties": [
              { "id": "unit", "value": "currencyUSD" },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "red", "value": 1 }
                  ]
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 8,
      "title": "Recent spans",
      "type": "table",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "argos-clickhouse" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "argos-clickhouse" },
          "editorType": "sql",
          "queryType": "table",
          "format": 1,
          "rawSql": "SELECT start_time, agent_name, step_type, name, status, round(cost_usd, 4) AS cost_usd FROM argos.spans ORDER BY start_time DESC LIMIT 50"
        }
      ],
      "options": { "showHeader": true },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto", "filterable": true } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "status" },
            "properties": [
              { "id": "custom.cellOptions", "value": { "type": "color-text" } },
              { "id": "mappings", "value": [
                { "type": "value", "options": { "error": { "color": "red", "index": 0 }, "ok": { "color": "green", "index": 1 } } }
              ] }
            ]
          }
        ]
      }
    },
    {
      "id": 9,
      "title": "Trace detail — $trace_id",
      "description": "Every span in the selected trace, indented by depth to show the parent→child tree. Reads the correlation engine's assembled output from argos.trace_nodes.",
      "type": "table",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 23 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "argos-clickhouse" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "argos-clickhouse" },
          "editorType": "sql",
          "queryType": "table",
          "format": 1,
          "rawSql": "SELECT step, agent_name, step_type, detail, duration_ms, cost_usd, status, attributes FROM (SELECT concat(repeat('    ', toUInt32(depth)), name) AS step, agent_name, step_type, multiIf(step_type = 'a2a_handoff', concat(JSONExtractString(attributes, 'a2a.from'), ' → ', JSONExtractString(attributes, 'a2a.to')), step_type = 'tool_call', concat(JSONExtractString(attributes, 'mcp.server'), '.', JSONExtractString(attributes, 'mcp.tool')), '') AS detail, round(duration_ms, 1) AS duration_ms, round(cost_usd, 6) AS cost_usd, status, attributes, order_index FROM argos.trace_nodes WHERE trace_id IN (SELECT trace_id FROM argos.spans GROUP BY trace_id, service_name HAVING concat(service_name, ' · ', if(countIf(status = 'error') > 0, 'fail', 'ok'), ' · ', formatDateTime(max(start_time), '%H:%i:%S', 'America/New_York')) = '$trace_id') ORDER BY written_at DESC LIMIT 1 BY span_id) ORDER BY order_index"
        }
      ],
      "options": { "showHeader": true, "cellHeight": "sm" },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto", "filterable": false } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "step" },
            "properties": [
              { "id": "custom.width", "value": 360 },
              { "id": "custom.cellOptions", "value": { "type": "auto", "wrapText": false } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "detail" },
            "properties": [
              { "id": "custom.width", "value": 280 },
              { "id": "displayName", "value": "who → whom / tool" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "duration_ms" },
            "properties": [{ "id": "unit", "value": "ms" }]
          },
          {
            "matcher": { "id": "byName", "options": "cost_usd" },
            "properties": [
              { "id": "unit", "value": "currencyUSD" },
              { "id": "decimals", "value": 6 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "status" },
            "properties": [
              { "id": "custom.cellOptions", "value": { "type": "color-background" } },
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "error": { "color": "red", "index": 0 }, "ok": { "color": "green", "index": 1 } } }
                ]
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "attributes" },
            "properties": [{ "id": "custom.width", "value": 520 }]
          }
        ]
      }
    },
    {
      "id": 10,
      "title": "Trace timeline — $trace_id",
      "description": "Horizontal timeline of the selected trace: every step is a dot at its real wall-clock start time (your local timezone). Green = ok, red = error — the failed steps stand out immediately. A dot's height is how long that step took (log scale), so slow steps sit high and instant ones sit low. Hover a dot for its duration and time; the full per-step detail (agent, cost, error) is in the Trace detail table above. Reads argos.spans.",
      "type": "timeseries",
      "gridPos": { "h": 11, "w": 24, "x": 0, "y": 35 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "argos-clickhouse" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "argos-clickhouse" },
          "editorType": "sql",
          "queryType": "table",
          "format": 1,
          "rawSql": "SELECT start_time AS time, if(status = 'ok', round(duration_ms, 2), NULL) AS `ok`, if(status = 'error', round(duration_ms, 2), NULL) AS `error` FROM argos.spans WHERE trace_id IN (SELECT trace_id FROM argos.spans GROUP BY trace_id, service_name HAVING concat(service_name, ' · ', if(countIf(status = 'error') > 0, 'fail', 'ok'), ' · ', formatDateTime(max(start_time), '%H:%i:%S', 'America/New_York')) = '$trace_id') ORDER BY start_time"
        }
      ],
      "options": {
        "legend": { "showLegend": true, "displayMode": "list", "placement": "bottom", "calcs": [] },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "min": 0.05,
          "custom": {
            "drawStyle": "points",
            "showPoints": "always",
            "pointSize": 16,
            "lineWidth": 0,
            "fillOpacity": 0,
            "axisLabel": "duration (ms, log)",
            "scaleDistribution": { "type": "log", "log": 10 }
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "ok" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }]
          },
          {
            "matcher": { "id": "byName", "options": "error" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
          }
        ]
      }
    },
    {
      "id": 11,
      "title": "Trace sequence — $trace_id",
      "description": "Left-to-right boxes-and-arrows flow of the selected trace, in execution order (argos.trace_nodes, order_index). Each box shows step number + type, agent, step name, duration and a ✓/✗; green = ok, red = error, so a failure shows up as a clear run of red boxes. Hover any box for full detail (agent, step, type, duration, cost, status, error). Rendered as styled HTML generated from the trace. Companion to the Trace detail table.",
      "type": "marcusolsson-dynamictext-panel",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 46 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "argos-clickhouse" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "argos-clickhouse" },
          "editorType": "sql",
          "queryType": "table",
          "format": 1,
          "rawSql": "SELECT concat('<div style=', char(34), 'display:flex;flex-wrap:wrap;align-items:stretch;gap:10px;font-family:sans-serif;padding:12px', char(34), '>', arrayStringConcat(arrayMap((i, ag, stp, typ, dur, cost, st, err) -> concat('<div title=', char(34), 'Agent: ', ag, '&#10;Step: ', stp, '&#10;Type: ', typ, '&#10;Duration: ', dur, ' ms&#10;Cost: $', cost, '&#10;Status: ', if(st = 'err', 'ERROR', 'ok'), if(st = 'err' AND err != '', concat('&#10;Error: ', err), ''), char(34), ' style=', char(34), 'background:', if(st = 'err', '#b71c1c', '#1b5e20'), ';color:#fff;border-radius:8px;padding:8px 12px;min-width:108px;max-width:180px;text-align:center;cursor:help', char(34), '>', '<div style=', char(34), 'font-size:10px;opacity:.7', char(34), '>', toString(i), '. ', typ, '</div>', '<div style=', char(34), 'font-weight:700;font-size:13px', char(34), '>', ag, '</div>', '<div style=', char(34), 'font-size:11px;opacity:.9;word-break:break-word', char(34), '>', stp, '</div>', '<div style=', char(34), 'font-size:11px;margin-top:3px', char(34), '>', dur, ' ms ', if(st = 'err', '✗', '✓'), '</div>', '</div>'), arrayEnumerate(ags), ags, stps, typs, durs, costs, sts, errs), concat('<span style=', char(34), 'align-self:center;color:#9aa6b2;font-size:20px', char(34), '>&#8594;</span>')), '</div>') AS html FROM (SELECT groupArray(ag) ags, groupArray(stp) stps, groupArray(typ) typs, groupArray(dur) durs, groupArray(cost) costs, groupArray(st) sts, groupArray(err) errs FROM (SELECT agent_name ag, replaceAll(name, '->', '→') stp, step_type typ, toString(round(duration_ms, 1)) dur, toString(round(cost_usd, 6)) cost, if(status = 'error', 'err', 'ok') st, replaceAll(replaceAll(ifNull(error_message, ''), char(34), char(39)), char(10), ' ') err, order_index FROM (SELECT agent_name, name, step_type, duration_ms, cost_usd, status, error_message, order_index FROM argos.trace_nodes WHERE trace_id IN (SELECT trace_id FROM argos.spans GROUP BY trace_id, service_name HAVING concat(service_name, ' · ', if(countIf(status = 'error') > 0, 'fail', 'ok'), ' · ', formatDateTime(max(start_time), '%H:%i:%S', 'America/New_York')) = '$trace_id') ORDER BY written_at DESC LIMIT 1 BY span_id) ORDER BY order_index))"
        }
      ],
      "options": {
        "content": "{{{html}}}",
        "defaultContent": "No trace selected — pick one from the Trace dropdown above.",
        "renderMode": "everyRow",
        "disableSanitize": true,
        "wrap": true
      }
    }
  ]
}
