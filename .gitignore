# ─── Python ───────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg
*.egg-info/
.eggs/
build/
dist/
sdist/
wheels/
*.manifest
*.spec

# Virtual environments
.venv/
venv/
env/
ENV/
.python-version

# Test / coverage / type-checker caches
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.mypy_cache/
.ruff_cache/
.cache/

# ─── Secrets & config (security-first: never commit these) ─────────────────
.env
.env.*
!.env.example
# The real bot-wrapping config (may name internal backends/models); the
# committed template is argos.config.example.yml.
argos.config.yml
*.pem
*.key
secrets.*

# ─── Local service data (Docker volumes for the stack) ─────────────────────
# These hold local Kafka / ClickHouse / Prometheus / Grafana state when the
# docker-compose stack runs. They are machine-local and must never be committed.
data/
.data/
kafka-data/
clickhouse-data/
prometheus-data/
grafana-data/
*.log

# ─── Editors / OS noise ────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*~
.DS_Store
Thumbs.db
