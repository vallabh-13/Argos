# Argos research-assistant demo — environment template.
#
# Copy this file to `.env` in THIS directory and fill it in:
#     cp examples/research-assistant/.env.example examples/research-assistant/.env
#
# `.env` is gitignored (security-first) — never commit real credentials.

# ── AWS Bedrock ────────────────────────────────────────────────────────────
# The model the demo calls. Read at runtime from this var — never hardcoded in
# the app. Claude 3 Haiku is cheap and, in us-east-1, needs no inference profile.
ARGOS_BEDROCK_MODEL=anthropic.claude-3-haiku-20240307-v1:0
AWS_REGION=us-east-1

# ── AWS credentials (NEVER commit real values) ─────────────────────────────
# Option A — static keys:
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
# Option B — a named profile instead (comment out the two lines above):
# AWS_PROFILE=your-profile

# ── Offline mock mode ──────────────────────────────────────────────────────
# Set to 1 to skip AWS entirely and use a canned LLM. Great for exercising the
# pipeline / dashboard with no credentials and no spend. The real agent logic
# (including the failure retry loop) still runs.
ARGOS_BEDROCK_MOCK=0

# ── Pipeline ───────────────────────────────────────────────────────────────
# Where to publish spans. Leave unset to print to the console instead.
# ARGOS_KAFKA_BOOTSTRAP=localhost:29092

# ── Failure-demo knob ──────────────────────────────────────────────────────
# How many times the search agent retries the tool before giving up. 6 is above
# the loop-detection threshold (5) so the failure scenario reliably trips the
# rule, yet bounded so a failing run can never run up an unbounded Bedrock bill.
ARGOS_DEMO_MAX_RETRIES=6
